pkgname=webhooknotif
pkgver=1
pkgrel=1
pkgdesc="A python script for monitoring webserver for webhook notification."
arch=('any')
url="https://github.com/wintersnowgod/PKGBUILD"
license=('GPL')
depends=('python' 'python-dbus')
source=('webhooknotif.py')
sha256sums=('11f129fd08467ac213b291c2dc6d3454b9e524e37e0eed580b082d08e3015238')

package() {
  mkdir -p ${pkgdir}/usr/bin
  install -Dm 755 ${srcdir}/webhooknotif.py ${pkgdir}/usr/bin/webhooknotif.py
}
