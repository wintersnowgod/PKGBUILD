pkgname=pkgmgr
pkgver=1
pkgrel=1
pkgdesc="A simple package manager for arch linux using fzf."
arch=('any')
depends=('bash' 'fzf' 'pacman-contrib')
optdepends=('xclip: For X11 copy to clipboard'
  'wl-copy: For Wayland Copy to clipboard')
source=("pkgmgr"
  "pkgmgr.desktop")
sha256sums=('a994e238111c3f96f4e5d0aa0552113670e70ca24e5d24b1b7e545f167f92064'
            '93caa3f225a3e191b5c2534303c711ea586a95898a741f7fbc3300a5e8cc0c11')

package() {
  install -Dm644 "${srcdir}/pkgmgr" "${pkgdir}/usr/bin/pkgmgr"
  install -Dm644 "${srcdir}/pkgmgr.desktop" "${pkgdir}/usr/share/applications/pkgmgr.desktop"
  chmod +x "${pkgdir}/usr/bin/pkgmgr"
}
